# Normalize all text files to LF on commit (prevents CRLF creeping in from Windows).
* text=auto eol=lf

# Shell scripts must always be LF — CRLF breaks shebangs and set -e inside Linux containers.
*.sh text eol=lf

# Config / YAML files — enforce LF for consistency.
*.yml  text eol=lf
*.yaml text eol=lf
*.conf text eol=lf
*.env  text eol=lf

# Binary files — no line ending conversion.
*.parquet binary
*.png     binary
*.jpg     binary
